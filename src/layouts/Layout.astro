---
import "../styles/global.css";
import { Menu, X } from "lucide-react";
import ThemeToggle from "../components/ThemeToggle.astro";
import { Font } from "astro:assets";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "MS Sports Academy - Building champions, one game at a time!",
} = Astro.props;

const navItems = [
    { name: "Home", href: "/" },
    { name: "About", href: "/#about" },
    { name: "Sports", href: "/#sports" },
    { name: "Gallery", href: "/gallery" },
    { name: "Contact", href: "/#contact" },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <Font cssVariable="--font-figtree" preload />
    </head>
    <body
        class="bg-[var(--bg-main)] text-[var(--text-main)] overflow-x-hidden transition-colors duration-300"
    >
        <!-- =========== NAVBAR =========== -->
        <header
            class="fixed w-full top-0 z-50 transition-all duration-300"
            id="navbar"
        >
            <!-- Navbar background: invisible at top, glass on scroll -->
            <div
                id="navbar-bg"
                class="absolute inset-0 glass-strong border-b border-[var(--border-color)]"
                style="opacity: 0; transition: opacity 0.4s ease;"
            ></div>

            <div
                class="container mx-auto px-4 py-4 relative flex justify-between items-center"
            >
                <!-- Logo -->
                <a
                    href="/"
                    class="text-2xl font-bold tracking-tighter group flex items-center gap-1"
                >
                    <span class="text-gradient">MS</span>
                    <span class="text-[var(--text-main)] group-hover:text-[var(--color-primary)] transition-colors duration-300">
                        Sports Academy
                    </span>
                </a>

                <!-- Desktop Nav -->
                <nav class="hidden md:flex gap-8 items-center">
                    {
                        navItems.map((item) => (
                            <a
                                href={item.href}
                                class="text-sm font-semibold text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-all relative group"
                            >
                                {item.name}
                                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-full transition-all duration-300" />
                            </a>
                        ))
                    }
                    <ThemeToggle />
                    <a href="/#contact" class="btn-primary text-sm px-6 py-2.5 gap-2">
                        Join Now
                    </a>
                </nav>

                <!-- Mobile Menu Button -->
                <div class="flex items-center gap-3 md:hidden">
                    <ThemeToggle />
                    <button
                        id="menu-btn"
                        class="p-2 rounded-xl glass text-[var(--text-main)] hover:border-[var(--color-primary)]/50 transition-all"
                        aria-label="Toggle menu"
                    >
                        <Menu className="w-5 h-5" id="menu-icon-open" />
                        <X className="w-5 h-5 hidden" id="menu-icon-close" />
                    </button>
                </div>
            </div>

            <!-- Mobile Nav -->
            <div
                id="mobile-menu"
                class="hidden md:hidden"
            >
                <div class="glass-strong border-t border-[var(--border-color)] px-4 py-6 flex flex-col gap-1">
                    {
                        navItems.map((item) => (
                            <a
                                href={item.href}
                                class="mobile-nav-link block px-4 py-3 rounded-xl text-[var(--text-muted)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/5 font-semibold transition-all"
                            >
                                {item.name}
                            </a>
                        ))
                    }
                    <a
                        href="/#contact"
                        class="btn-primary mt-4 justify-center text-sm"
                    >
                        Join Now
                    </a>
                </div>
            </div>
        </header>

        <!-- =========== PAGE CONTENT =========== -->
        <slot />

        <!-- =========== PRE-FOOTER CTA =========== -->
        <section class="relative py-24 overflow-hidden">
            <!-- Background -->
            <div class="absolute inset-0 -z-10">
                <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/15 via-[var(--bg-card)] to-[var(--color-secondary)]/10"></div>
                <!-- Decorative orbs -->
                <div class="absolute -top-20 left-1/4 w-72 h-72 bg-[var(--color-primary)]/10 rounded-full blur-3xl"></div>
                <div class="absolute -bottom-20 right-1/4 w-72 h-72 bg-[var(--color-secondary)]/10 rounded-full blur-3xl"></div>
            </div>

            <div class="container mx-auto px-4 text-center">
                <!-- Badge -->
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass mb-6 text-xs font-semibold uppercase tracking-widest text-[var(--color-primary)]">
                    🏆 &nbsp;Your Journey Starts Here
                </div>

                <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-5 leading-tight">
                    Ready to Champion
                    <span class="text-gradient"> Your Sport?</span>
                </h2>

                <p class="text-[var(--text-muted)] mb-10 max-w-xl mx-auto text-lg leading-relaxed">
                    Join hundreds of athletes who've transformed their game at MS Sports Academy — professional coaching, world-class facilities.
                </p>

                <div class="flex items-center justify-center gap-4 flex-wrap">
                    <a href="/#contact" class="btn-primary gap-2 text-sm px-8 py-3">
                        Start Your Journey
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                    </a>
                    <a
                        href="https://wa.me/919080187219"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-secondary gap-2 text-sm px-8 py-3"
                    >
                        <svg class="w-4 h-4 text-[#25D366]" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                        </svg>
                        WhatsApp Us
                    </a>
                </div>
            </div>
        </section>

        <!-- =========== FOOTER =========== -->
        <footer class="relative overflow-hidden border-t border-[var(--border-color)]">
            <!-- Rainbow top line -->
            <div class="h-px w-full bg-gradient-to-r from-[var(--color-primary)] via-[var(--color-secondary)] to-[var(--color-accent)]"></div>

            <div class="absolute inset-0 bg-gradient-to-b from-[var(--bg-card)] to-[var(--bg-main)] -z-10"></div>

            <div class="container mx-auto px-4 pt-16 pb-10">
                <div class="grid md:grid-cols-3 gap-12 mb-12">
                    <!-- Brand -->
                    <div>
                        <div class="flex items-center gap-1 mb-4">
                            <span class="text-2xl font-bold text-gradient">MS</span>
                            <span class="text-2xl font-bold text-[var(--text-main)]"> Sports Academy</span>
                        </div>
                        <p class="text-[var(--text-muted)] text-sm leading-relaxed mb-6">
                            Building champions, one game at a time. Join us to
                            unleash your potential and achieve excellence in
                            Perundurai, Tamil Nadu.
                        </p>
                        <!-- Social Links -->
                        <div class="flex gap-3">
                            <a
                                href="#"
                                aria-label="Facebook"
                                class="w-10 h-10 rounded-full glass flex items-center justify-center hover:border-[var(--color-primary)]/60 hover:text-[var(--color-primary)] transition-all duration-300 hover:-translate-y-1"
                            >
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                                </svg>
                            </a>
                            <a
                                href="#"
                                aria-label="Instagram"
                                class="w-10 h-10 rounded-full glass flex items-center justify-center hover:border-[var(--color-accent)]/60 hover:text-[var(--color-accent)] transition-all duration-300 hover:-translate-y-1"
                            >
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                                </svg>
                            </a>
                            <a
                                href="https://wa.me/919080187219"
                                aria-label="WhatsApp"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="w-10 h-10 rounded-full glass flex items-center justify-center hover:border-[#25D366]/60 hover:text-[#25D366] transition-all duration-300 hover:-translate-y-1"
                            >
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <!-- Quick Links -->
                    <div>
                        <h4 class="font-bold mb-6 text-[var(--text-main)] uppercase tracking-widest text-xs">
                            Quick Links
                        </h4>
                        <ul class="space-y-3 text-sm">
                            {[
                                { href: "/#about", label: "About Us" },
                                { href: "/#sports", label: "Sports Programs" },
                                { href: "/gallery", label: "Gallery" },
                                { href: "/#contact", label: "Contact" },
                            ].map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        class="text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-2 group"
                                    >
                                        <span class="w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-4 transition-all duration-300" />
                                        {link.label}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Contact -->
                    <div>
                        <h4 class="font-bold mb-6 text-[var(--text-main)] uppercase tracking-widest text-xs">
                            Contact Us
                        </h4>
                        <div class="space-y-4 text-sm text-[var(--text-muted)]">
                            <div class="flex items-start gap-3">
                                <svg class="w-4 h-4 mt-0.5 shrink-0 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <p class="leading-relaxed">
                                    Perundurai, Erode<br />Tamil Nadu - 638 052
                                </p>
                            </div>
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 shrink-0 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                                <p>
                                    <a href="tel:9080187219" class="hover:text-[var(--color-primary)] transition-colors">9080187219</a>
                                    &nbsp;/&nbsp;
                                    <a href="tel:9788654453" class="hover:text-[var(--color-primary)] transition-colors">9788654453</a>
                                </p>
                            </div>
                            <div class="flex items-center gap-3">
                                <svg class="w-4 h-4 shrink-0 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                                <a
                                    href="mailto:contact@mssports.academy"
                                    class="hover:text-[var(--color-primary)] transition-colors"
                                >
                                    contact@mssports.academy
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bottom bar -->
                <div class="pt-8 border-t border-[var(--border-color)] flex flex-col md:flex-row justify-between items-center gap-4">
                    <p class="text-[var(--text-dimmed)] text-sm">
                        &copy; {new Date().getFullYear()} MS Sports Academy. All rights reserved.
                    </p>
                    <p class="text-[var(--text-dimmed)] text-sm">
                        Built with passion for sports 🏆
                    </p>
                </div>
            </div>
        </footer>

        <!-- =========== GLOBAL SCRIPTS =========== -->
        <script>
            // ---- Navbar scroll transparency ----
            const navbarBg = document.getElementById("navbar-bg");
            const updateNavbar = () => {
                if (navbarBg) {
                    navbarBg.style.opacity = window.scrollY > 60 ? "1" : "0";
                }
            };
            window.addEventListener("scroll", updateNavbar, { passive: true });
            updateNavbar();

            // ---- Mobile menu toggle ----
            const menuBtn = document.getElementById("menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");
            const menuIconOpen = document.getElementById("menu-icon-open");
            const menuIconClose = document.getElementById("menu-icon-close");
            let menuOpen = false;

            menuBtn?.addEventListener("click", () => {
                menuOpen = !menuOpen;
                if (menuOpen) {
                    mobileMenu?.classList.remove("hidden");
                    menuIconOpen?.classList.add("hidden");
                    menuIconClose?.classList.remove("hidden");
                } else {
                    mobileMenu?.classList.add("hidden");
                    menuIconOpen?.classList.remove("hidden");
                    menuIconClose?.classList.add("hidden");
                }
            });

            // Close mobile menu when a link is clicked
            document.querySelectorAll(".mobile-nav-link").forEach((link) => {
                link.addEventListener("click", () => {
                    mobileMenu?.classList.add("hidden");
                    menuIconOpen?.classList.remove("hidden");
                    menuIconClose?.classList.add("hidden");
                    menuOpen = false;
                });
            });

            // ---- Intersection Observer for scroll-reveal ----
            const revealObserver = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("revealed");
                            revealObserver.unobserve(entry.target);
                        }
                    });
                },
                { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
            );

            document.querySelectorAll(".scroll-reveal").forEach((el) => {
                revealObserver.observe(el);
            });
        </script>
    </body>
</html>
