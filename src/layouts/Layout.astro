---
import "../styles/global.css";
import { Menu, X } from "lucide-react";
import ThemeToggle from "../components/ThemeToggle.astro";
import { Font } from "astro:assets";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "MS Sports Academy - Building champions, one game at a time!",
} = Astro.props;

const navItems = [
    { name: "Home", href: "/" },
    { name: "About", href: "/#about" },
    { name: "Sports", href: "/#sports" },
    { name: "Gallery", href: "/gallery" },
    { name: "Contact", href: "/#contact" },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <Font cssVariable="--font-figtree" preload />
    </head>
    <body
        class="bg-[var(--bg-main)] text-[var(--text-main)] overflow-x-hidden transition-colors duration-300"
    >
        <header
            class="fixed w-full top-0 z-50 transition-all duration-300"
            id="navbar"
        >
            <div
                class="absolute inset-0 glass-strong border-b border-[var(--border-color)]"
            >
            </div>
            <div
                class="container mx-auto px-4 py-5 relative flex justify-between items-center"
            >
                <a
                    href="/"
                    class="text-2xl font-display font-bold tracking-tighter group"
                >
                    <span
                        class="text-gradient group-hover:text-gradient-secondary transition-all"
                    >
                        MS</span
                    > Sports Acadmey
                </a>

                <!-- Desktop Nav -->
                <nav class="hidden md:flex gap-8 items-center">
                    {
                        navItems.map((item) => (
                            <a
                                href={item.href}
                                class="text-sm font-semibold text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-all relative group"
                            >
                                {item.name}
                                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-full transition-all duration-300" />
                            </a>
                        ))
                    }
                    <ThemeToggle />
                    <a href="/#contact" class="btn-primary text-sm px-6 py-2.5">
                        Join Now
                    </a>
                </nav>

                <!-- Mobile Menu Button -->
                <div class="flex items-center gap-4 md:hidden">
                    <ThemeToggle />
                    <button id="menu-btn" class="text-[var(--text-main)]">
                        <Menu className="w-6 h-6" />
                    </button>
                </div>
            </div>

            <!-- Mobile Nav -->
            <div
                id="mobile-menu"
                class="hidden absolute top-full left-0 w-full bg-[var(--bg-main)] border-b border-[var(--border-color)] p-4 md:hidden flex-col gap-4"
            >
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class="block text-[var(--text-muted)] hover:text-[var(--color-primary)] py-2"
                        >
                            {item.name}
                        </a>
                    ))
                }
            </div>
        </header>

        <slot />

        <footer
            class="relative overflow-hidden border-t border-[var(--border-color)] py-16 mt-20"
        >
            <div
                class="absolute inset-0 bg-gradient-to-b from-[var(--bg-card)] to-[var(--bg-main)] -z-10"
            >
            </div>

            <div class="container mx-auto px-4">
                <div class="grid md:grid-cols-3 gap-12 mb-12">
                    <div>
                        <h3 class="text-2xl font-bold mb-4">
                            MS<span class="text-gradient"> Sports</span>
                        </h3>
                        <p
                            class="text-[var(--text-muted)] text-sm leading-relaxed mb-6"
                        >
                            Building champions, one game at a time. Join us to
                            unleash your potential and achieve excellence.
                        </p>
                        <div class="flex gap-3">
                            <a
                                href="#"
                                class="w-10 h-10 rounded-full glass flex items-center justify-center hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-all"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                                    ></path></svg
                                >
                            </a>
                            <a
                                href="#"
                                class="w-10 h-10 rounded-full glass flex items-center justify-center hover:border-[var(--color-secondary)] hover:text-[var(--color-secondary)] transition-all"
                            >
                                <svg
                                    class="w-5 h-5"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                    ><path
                                        d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                                    ></path></svg
                                >
                            </a>
                        </div>
                    </div>
                    <div>
                        <h4 class="font-bold mb-6 text-[var(--text-main)]">
                            Quick Links
                        </h4>
                        <ul class="space-y-3 text-sm">
                            <li>
                                <a
                                    href="/#about"
                                    class="text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-2 group"
                                >
                                    <span
                                        class="w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-4 transition-all"
                                    ></span>
                                    About Us
                                </a>
                            </li>
                            <li>
                                <a
                                    href="/#sports"
                                    class="text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-2 group"
                                >
                                    <span
                                        class="w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-4 transition-all"
                                    ></span>
                                    Sports
                                </a>
                            </li>
                            <li>
                                <a
                                    href="/gallery"
                                    class="text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-2 group"
                                >
                                    <span
                                        class="w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-4 transition-all"
                                    ></span>
                                    Gallery
                                </a>
                            </li>
                            <li>
                                <a
                                    href="/#contact"
                                    class="text-[var(--text-muted)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-2 group"
                                >
                                    <span
                                        class="w-0 h-0.5 bg-[var(--color-primary)] group-hover:w-4 transition-all"
                                    ></span>
                                    Contact
                                </a>
                            </li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="font-bold mb-6 text-[var(--text-main)]">
                            Contact
                        </h4>
                        <div class="space-y-3 text-sm text-[var(--text-muted)]">
                            <p class="leading-relaxed">
                                Perundurai, Erode<br />Tamil Nadu - 638 052
                            </p>
                            <p>
                                <a
                                    href="tel:9080187219"
                                    class="hover:text-[var(--color-primary)] transition-colors"
                                    >9080187219</a
                                > /
                                <a
                                    href="tel:9788654453"
                                    class="hover:text-[var(--color-primary)] transition-colors"
                                    >9788654453</a
                                >
                            </p>
                            <p>
                                <a
                                    href="mailto:contact@mssports.academy"
                                    class="hover:text-[var(--color-primary)] transition-colors"
                                >
                                    contact@mssports.academy
                                </a>
                            </p>
                        </div>
                    </div>
                </div>

                <div
                    class="pt-8 border-t border-[var(--border-color)] text-center"
                >
                    <p class="text-[var(--text-muted)] text-sm">
                        &copy; {new Date().getFullYear()} MS Sports Academy. All rights
                        reserved. Built with passion for sports.
                    </p>
                </div>
            </div>
        </footer>

        <script>
            const menuBtn = document.getElementById("menu-btn");
            const mobileMenu = document.getElementById("mobile-menu");

            menuBtn?.addEventListener("click", () => {
                mobileMenu?.classList.toggle("hidden");
            });
        </script>
    </body>
</html>
