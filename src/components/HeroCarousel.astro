---
import { ArrowRight, Sparkles } from "lucide-react";
import type { CloudinaryImage } from "../lib/cloudinary";

interface Props {
    images: CloudinaryImage[];
}

const { images } = Astro.props;
---

<div
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
    id="hero-carousel"
>
    <!-- Background Images with enhanced overlay -->
    {
        images.map((img, index) => (
            <div
                class={`absolute inset-0 z-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? "opacity-100" : "opacity-0"}`}
                data-carousel-item
            >
                <img
                    src={img.secure_url}
                    alt="Sports Academy Background"
                    class="w-full h-full object-cover scale-105"
                />
                <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-black/70" />
                <div class="absolute inset-0 bg-[var(--color-primary)]/5" />
            </div>
        ))
    }

    <!-- Animated gradient overlay -->
    <div
        class="absolute inset-0 z-[1] bg-gradient-to-br from-[var(--color-primary)]/10 via-transparent to-[var(--color-secondary)]/10 opacity-60"
    >
    </div>

    <!-- Content -->
    <div class="relative z-10 container mx-auto px-4 text-center text-white">
        <!-- Badge -->
        <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full hero-stat-card mb-6 animate-[fade-in_0.6s_ease-out]"
        >
            <Sparkles className="w-4 h-4 text-[var(--color-primary)]" />
            <span class="text-sm font-medium text-white"
                >Premier Sports Academy in Perundurai</span
            >
        </div>

        <h1
            class="text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-tight animate-[slide-up_0.8s_ease-out_0.2s_both]"
        >
            Elevate Your <span class="text-gradient">Game</span>
        </h1>
        <p
            class="text-lg md:text-2xl text-gray-200 mb-10 max-w-3xl mx-auto px-4 leading-relaxed animate-[slide-up_0.8s_ease-out_0.4s_both]"
        >
            Train with professional coaches, world-class facilities, and a
            community of champions. Your journey to excellence starts here.
        </p>
        <div
            class="flex flex-col md:flex-row items-center justify-center gap-4 md:gap-6 animate-[slide-up_0.8s_ease-out_0.6s_both]"
        >
            <a
                href="#contact"
                class="btn-primary flex items-center gap-2 w-full md:w-auto justify-center group"
            >
                Start Your Journey
                <ArrowRight
                    className="w-5 h-5 group-hover:translate-x-1 transition-transform"
                />
            </a>
            <a
                href="/gallery"
                class="btn-secondary w-full md:w-auto backdrop-blur-md"
            >
                Explore Gallery
            </a>
        </div>

        <!-- Stats Mini Cards -->
        <div
            class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-16 max-w-4xl mx-auto animate-[fade-in_1s_ease-out_0.8s_both]"
        >
            <div class="hero-stat-card rounded-2xl p-4">
                <div class="text-3xl md:text-4xl font-bold text-gradient mb-1">
                    4+
                </div>
                <div
                    class="text-xs md:text-sm text-white/70 uppercase tracking-wider"
                >
                    Sports
                </div>
            </div>
            <div class="hero-stat-card rounded-2xl p-4">
                <div
                    class="text-3xl md:text-4xl font-bold text-gradient-secondary mb-1"
                >
                    30+
                </div>
                <div
                    class="text-xs md:text-sm text-white/70 uppercase tracking-wider"
                >
                    Years Exp.
                </div>
            </div>
            <div class="hero-stat-card rounded-2xl p-4">
                <div
                    class="text-3xl md:text-4xl font-bold text-gradient-accent mb-1"
                >
                    100+
                </div>
                <div
                    class="text-xs md:text-sm text-white/70 uppercase tracking-wider"
                >
                    Students
                </div>
            </div>
            <div class="hero-stat-card rounded-2xl p-4">
                <div class="text-3xl md:text-4xl font-bold text-gradient mb-1">
                    20+
                </div>
                <div
                    class="text-xs md:text-sm text-white/70 uppercase tracking-wider"
                >
                    Champions
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce text-white/50 z-20"
    >
        <div
            class="w-6 h-10 border-2 border-current rounded-full flex justify-center pt-2"
        >
            <div class="w-1 h-2 bg-current rounded-full animate-pulse"></div>
        </div>
    </div>
</div>

<script>
    const items = document.querySelectorAll("[data-carousel-item]");
    let currentIndex = 0;

    if (items.length > 1) {
        setInterval(() => {
            items[currentIndex].classList.remove("opacity-100");
            items[currentIndex].classList.add("opacity-0");

            currentIndex = (currentIndex + 1) % items.length;

            items[currentIndex].classList.remove("opacity-0");
            items[currentIndex].classList.add("opacity-100");
        }, 5000); // Change every 5 seconds
    }
</script>
