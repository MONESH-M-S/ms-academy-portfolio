---
import { ArrowRight, Sparkles } from "lucide-react";
import type { CloudinaryImage } from "../lib/cloudinary";

interface Props {
    images: CloudinaryImage[];
}

const { images } = Astro.props;
---

<div
    class="relative min-h-screen flex items-center justify-center overflow-hidden"
    id="hero-carousel"
>
    <!-- Background Images with Ken Burns effect -->
    {
        images.map((img, index) => (
            <div
                class={`absolute inset-0 z-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? "opacity-100" : "opacity-0"}`}
                data-carousel-item
            >
                <img
                    src={img.secure_url}
                    alt="MS Sports Academy"
                    class="w-full h-full object-cover"
                    loading={index === 0 ? "eager" : "lazy"}
                />
                <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/45 to-black/80" />
                <div class="absolute inset-0 bg-gradient-to-r from-black/30 via-transparent to-black/20" />
            </div>
        ))
    }

    <!-- Subtle grid texture overlay -->
    <div
        class="absolute inset-0 z-[1] pointer-events-none opacity-[0.03]"
        style="background-image: linear-gradient(rgba(163,230,53,1) 1px, transparent 1px), linear-gradient(90deg, rgba(163,230,53,1) 1px, transparent 1px); background-size: 64px 64px;"
    ></div>

    <!-- Gradient accent -->
    <div
        class="absolute inset-0 z-[1] bg-gradient-to-br from-[var(--color-primary)]/6 via-transparent to-[var(--color-secondary)]/6"
    ></div>

    <!-- Floating orbs — hidden on mobile to prevent layout issues -->
    <div class="hidden md:block absolute top-1/4 left-10 w-64 h-64 bg-[var(--color-primary)]/10 rounded-full blur-3xl z-[1] animate-[float-slow_8s_ease-in-out_infinite]"></div>
    <div class="hidden md:block absolute bottom-1/4 right-10 w-56 h-56 bg-[var(--color-secondary)]/10 rounded-full blur-3xl z-[1] animate-[float-slow_10s_ease-in-out_3s_infinite]"></div>

    <!-- Content — pt clears fixed navbar on mobile, pb clears dots/scroll indicator -->
    <div class="relative z-10 w-full container mx-auto px-5 text-center text-white pt-24 pb-28 md:py-0">

        <!-- Badge -->
        <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full hero-stat-card mb-6 animate-[fade-in_0.6s_ease-out] max-w-[90vw]"
        >
            <Sparkles className="w-4 h-4 shrink-0 text-[var(--color-primary)]" />
            <span class="text-xs sm:text-sm font-semibold text-white tracking-wide leading-snug">
                Premier Sports Academy in Perundurai
            </span>
        </div>

        <!-- Headline -->
        <h1
            class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold mb-4 md:mb-6 leading-tight animate-[slide-up_0.8s_ease-out_0.2s_both]"
        >
            Elevate Your <span class="text-gradient">Game</span>
        </h1>

        <!-- Sub headline -->
        <p
            class="text-base sm:text-lg md:text-xl text-white/80 mb-8 md:mb-10 max-w-xl mx-auto leading-relaxed animate-[slide-up_0.8s_ease-out_0.4s_both]"
        >
            Train with professional coaches, world-class facilities, and a
            community of champions. Your journey starts here.
        </p>

        <!-- CTA Buttons -->
        <div
            class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10 md:mb-14 animate-[slide-up_0.8s_ease-out_0.6s_both]"
        >
            <a
                href="#contact"
                class="btn-primary flex items-center gap-2 w-full sm:w-auto justify-center text-sm md:text-base px-7 py-3 group"
            >
                Start Your Journey
                <ArrowRight
                    className="w-4 h-4 group-hover:translate-x-1 transition-transform"
                />
            </a>
            <a
                href="/gallery"
                class="btn-secondary w-full sm:w-auto justify-center text-sm md:text-base px-7 py-3"
            >
                Explore Gallery
            </a>
        </div>

        <!-- Stats Mini Cards -->
        <div
            class="grid grid-cols-4 gap-2 sm:gap-4 max-w-sm sm:max-w-xl md:max-w-3xl mx-auto animate-[fade-in_1s_ease-out_0.8s_both]"
        >
            {[
                { value: "4+", label: "Sports", gradient: "text-gradient" },
                { value: "30+", label: "Yrs Exp.", gradient: "text-gradient-secondary" },
                { value: "100+", label: "Students", gradient: "text-gradient-accent" },
                { value: "20+", label: "Champs", gradient: "text-gradient" },
            ].map((stat) => (
                <div class="hero-stat-card rounded-xl sm:rounded-2xl p-2.5 sm:p-4 text-center">
                    <div class={`text-xl sm:text-3xl md:text-4xl font-bold mb-0.5 sm:mb-1 ${stat.gradient}`}>
                        {stat.value}
                    </div>
                    <div class="text-[10px] sm:text-xs text-white/60 uppercase tracking-wider font-semibold leading-tight">
                        {stat.label}
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- Carousel Dot Indicators -->
    {images.length > 1 && (
        <div
            class="absolute bottom-14 sm:bottom-16 left-1/2 -translate-x-1/2 flex items-center gap-2 z-20"
            id="carousel-dots"
        >
            {images.map((_, i) => (
                <button
                    class={`carousel-dot h-1.5 rounded-full transition-all duration-500 ${i === 0 ? "w-6 bg-[var(--color-primary)]" : "w-1.5 bg-white/40 hover:bg-white/70"}`}
                    data-dot-index={i}
                    aria-label={`Slide ${i + 1}`}
                />
            ))}
        </div>
    )}

    <!-- Scroll Indicator -->
    <div
        class="absolute bottom-5 left-1/2 transform -translate-x-1/2 text-white/50 z-20 animate-bounce"
    >
        <div
            class="w-5 h-8 border-2 border-current rounded-full flex justify-center pt-1.5"
        >
            <div class="w-0.5 h-1.5 bg-current rounded-full animate-pulse"></div>
        </div>
    </div>
</div>

<script>
    const items = document.querySelectorAll<HTMLElement>("[data-carousel-item]");
    const dots = document.querySelectorAll<HTMLButtonElement>(".carousel-dot");
    let currentIndex = 0;
    let intervalId: ReturnType<typeof setInterval>;

    function goToSlide(index: number) {
        items[currentIndex].classList.remove("opacity-100");
        items[currentIndex].classList.add("opacity-0");
        dots[currentIndex]?.classList.remove("w-6", "bg-[var(--color-primary)]");
        dots[currentIndex]?.classList.add("w-1.5", "bg-white/40");

        currentIndex = index;

        items[currentIndex].classList.remove("opacity-0");
        items[currentIndex].classList.add("opacity-100");
        dots[currentIndex]?.classList.remove("w-1.5", "bg-white/40");
        dots[currentIndex]?.classList.add("w-6", "bg-[var(--color-primary)]");
    }

    function startAutoplay() {
        if (items.length <= 1) return;
        intervalId = setInterval(() => {
            const next = (currentIndex + 1) % items.length;
            goToSlide(next);
        }, 5500);
    }

    dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
            clearInterval(intervalId);
            goToSlide(i);
            startAutoplay();
        });
    });

    startAutoplay();
</script>
